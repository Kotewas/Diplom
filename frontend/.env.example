# Optional. By default frontend calls /api and uses Vite proxy to http://localhost:8080 in dev mode.
# If you want to call backend by absolute URL, uncomment:
# VITE_API_BASE_URL=http://localhost:8080

# Optional. Dev proxy target for /api in Vite.
# Useful when backend runs on 8081:
# VITE_DEV_API_TARGET=http://localhost:8081
